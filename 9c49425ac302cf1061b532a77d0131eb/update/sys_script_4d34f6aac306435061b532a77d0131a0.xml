        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

    var shortDesc = current.short_description.toString().toLowerCase();

    var mapping = new GlideRecord('x_2032008_incide_0_incident_keyword_mapping');
    mapping.addQuery('active', true);
    mapping.query();

    while (mapping.next()) {
        var keyword = mapping.keyword.toString().toLowerCase();

        if (keyword && shortDesc.indexOf(keyword) !== -1) {
            current.category = mapping.category.toString();
            current.subcategory = mapping.subcategory.toString();
            current.assignment_group = mapping.assignment_group;
            break;
        }
    }

})(current, previous);]]></script>
